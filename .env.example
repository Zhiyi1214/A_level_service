# AI Assistant Backend Configuration

# Dify API Configuration
# Docker 容器内访问宿主机 Dify:
#   DIFY_API_URL=http://host.docker.internal/v1
# 宿主机本地运行:
#   DIFY_API_URL=http://localhost/v1
DIFY_API_URL=http://localhost/v1
SOURCES_CONFIG_PATH=./config/sources.json

# API keys — 变量名须与 config/sources.json 中 auth_ref 一致
DIFY_API_KEY_AQA=your_aqa_api_key_here
DIFY_API_KEY_CIE=your_cie_api_key_here
DIFY_API_KEY_EDX=your_edx_api_key_here

# Flask
FLASK_ENV=development
HOST=0.0.0.0
PORT=5000
SECRET_KEY=change_me_to_a_random_string

# —— 数据与 Session ——
# DATABASE_URL 必填（仅支持 PostgreSQL）。本机直接运行 python app.py 时请指向可访问的 Postgres，例如：
DATABASE_URL=postgresql://a_level:a_level_dev_change_me@127.0.0.1:5432/a_level
# Docker Compose 中 ai-assistant 服务会通过 compose 的 environment 再次注入 DATABASE_URL（连服务名 postgres），
# 若仅在容器内运行应用，.env 里可保留上述占位或与 POSTGRES_PASSWORD 一致的连接串。
# REDIS_URL=redis://redis:6379/0
# 限流与多 worker 共享配额（可选，与 REDIS 同实例不同 DB）
# RATELIMIT_STORAGE_URI=redis://redis:6379/1
# Postgres 容器密码，须与 DATABASE_URL 中一致
# POSTGRES_PASSWORD=a_level_dev_change_me

# File Upload
MAX_CONTENT_LENGTH=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,txt,doc,docx

# MinIO / S3（对象存储；与 docker-compose 中 minio 服务对应）
# S3_ENDPOINT_URL：应用进程访问 MinIO 的地址（容器内常用 http://minio:9000）
# 浏览器经同源 GET /api/media/<object_key> 拉图（须登录或 ?user_id=），勿再对外反代整桶路径。
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin_change_me
# S3_BUCKET=a-level-uploads
# S3_REGION=us-east-1
# custom_api 等内网上游拉对象时的预签名有效期（秒），默认 3600
# S3_PRESIGN_EXPIRES=3600

# CORS
CORS_ORIGINS=*

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Frontend version（页脚与 compose 默认注入；静态资源 ?v= 另含文件 mtime）
FRONTEND_VERSION=47
# Docker 镜像标签（可选，与 docker-compose 中 APP_IMAGE_TAG 一致）
# APP_IMAGE_TAG=47

# —— Google 登录（可选）—— 三者齐全时启用；与 Google Cloud Console 重定向 URI 须一致
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 显式回调地址（可留空；留空时按当前请求入口动态生成，须与 Google Console 一致）
# GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/google/callback
# 生产环境 HTTPS 建议：SESSION_COOKIE_SECURE=true；本地 http://localhost 开发请保持 false/留空
