# AI Assistant Backend Configuration

# Dify API Configuration
# 本应用（ai-assistant）在 Docker 里、Dify 在宿主机 80（docker-nginx-1）:
#   DIFY_API_URL=http://host.docker.internal/v1
# 本应用仅在宿主机运行（python app.py）:
#   DIFY_API_URL=http://localhost/v1
# 与 Dify 在同一 docker 网络时可用服务名（见各自 compose）。
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=your_api_key_here

# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# File Upload Configuration
MAX_CONTENT_LENGTH=52428800  # 50MB
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,txt,doc,docx

# CORS Configuration
CORS_ORIGINS=*

